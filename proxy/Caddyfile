{$PROXY_DOMAIN} {
	# Temporary access logging for incident troubleshooting -- remove after a few days.
	log

	@wellknown path /.well-known/*
	handle @wellknown {
		uri strip_prefix /.well-known
		root * /srv/well-known
		file_server
	}

	@oauth path /oauth/callback*
	handle @oauth {
		respond "You can close this tab and return to the app." 200
	}

	@oauthtoken path /oauth/token
	handle @oauthtoken {
		reverse_proxy oauth-relay:8090
	}

	handle {
		reverse_proxy tesla-http-proxy:443 {
			transport http {
				tls_insecure_skip_verify
			}
		}
	}
}
